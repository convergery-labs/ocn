# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=research-universe
POSTGRES_USER=research-universe
POSTGRES_PASSWORD=

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4-6

# CORS - comma-separated list of allowed origins (Lovable domain etc.)
CORS_ORIGINS=http://localhost:3000

# Seed script - path to the xlsx source file
UNIVERSE_XLSX_PATH=/data/AI_Economy_Universe_Final.xlsx

# ALB path prefix - set to /universe in production, leave empty for local dev
API_PREFIX=
