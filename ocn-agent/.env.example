# Required. Internal news-retrieval service URL
NEWS_RETRIEVAL_URL=http://news-retrieval:8000
# Required. API key for authenticating calls to news-retrieval
NEWS_RETRIEVAL_API_KEY=
# Required. Anthropic API key for domain resolution LLM calls
ANTHROPIC_API_KEY=
# Required. Claude model ID to use for domain resolution
AGENT_LLM_MODEL=claude-sonnet-4-6
# Required. Public base URL of this service (used to construct internal callbacks)
AGENT_BASE_URL=http://ocn-agent:8003
# Optional. Confidence threshold below which a clarification is requested (default: 0.7)
CONFIDENCE_THRESHOLD=0.7
