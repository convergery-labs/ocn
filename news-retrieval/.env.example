# Required. PostgreSQL connection for news-retrieval
POSTGRES_PASSWORD=
POSTGRES_HOST=postgres-news
POSTGRES_PORT=5432
POSTGRES_DB=news-retrieval
POSTGRES_USER=news-retrieval

# Required. OpenRouter credentials
OPENROUTER_API_KEY=
OPENROUTER_MODEL=

# Optional. SerpAPI key for Google News search sources.
# If unset, serpapi sources are skipped gracefully.
SERPAPI_KEY=

# Optional. Alpha Vantage premium API key for company-specific news (company_news domain).
# Premium tier: 75 calls/min. Fetcher caps at 60/min internally (1 call/sec).
# If unset, alpha_vantage sources are skipped gracefully.
ALPHA_VANTAGE_API_KEY=

# Optional. research-universe service base URL for dynamic ticker fetching.
# In AWS: http://research-universe.<env>.ocn.internal:8007
# If unset, only config.tickers from seed.py are used.
RESEARCH_UNIVERSE_URL=

# Optional. Service API key (ru_ prefix) for authenticating calls to research-universe.
# Create via: docker exec -it research-universe python -m src users create
# If unset, dynamic ticker fetch falls back to config.tickers in seed.py.
RESEARCH_UNIVERSE_API_KEY=
