# =============================================================================
# auth-service
# =============================================================================

# Required. PostgreSQL password for the auth-service database
AUTH_POSTGRES_PASSWORD=

# Required. Secret used to sign JWTs (or equivalent session tokens)
# AUTH_JWT_SECRET=

# =============================================================================
# news-retrieval
# =============================================================================

# Required. Server-level API key for OpenRouter
OPENROUTER_API_KEY=

# Required. Default model string for relevance filtering
# e.g. openrouter/anthropic/claude-3-haiku
OPENROUTER_MODEL=

# Required. Plaintext admin API key seeded into the DB on first startup
ADMIN_API_KEY=

# Required. PostgreSQL password for the news-retrieval database
NEWS_POSTGRES_PASSWORD=

# Optional overrides (defaults shown)
# NEWS_POSTGRES_HOST=localhost
# NEWS_POSTGRES_PORT=5432
# NEWS_POSTGRES_DB=news-retrieval
# NEWS_POSTGRES_USER=news-retrieval

# =============================================================================
# signal-detection
# =============================================================================

# Required. PostgreSQL password for the signal-detection database
SIGNAL_POSTGRES_PASSWORD=

# Optional. Qdrant host (default: qdrant, the Docker Compose service name)
# QDRANT_HOST=qdrant
# QDRANT_PORT=6333
