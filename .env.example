# =============================================================================
# auth-service
# =============================================================================

# Required. PostgreSQL connection details for the auth-service database
AUTH_POSTGRES_PASSWORD=
AUTH_POSTGRES_DB=auth-service
AUTH_POSTGRES_USER=auth-service

# Required. Plaintext admin API key seeded into the DB on first startup
# Must be of the form csec_<64 hex chars>
AUTH_ADMIN_API_KEY=

# Required. PostgreSQL host for auth-service (Docker service name)
AUTH_POSTGRES_HOST=postgres-auth

# =============================================================================
# news-retrieval
# =============================================================================

# Required. Server-level API key for OpenRouter
OPENROUTER_API_KEY=

# Required. Default model string for LLM calls (relevance filtering, claim extraction)
# e.g. inclusionai/ling-2.6-flash:free  (formerly inclusionai/ling-2.6-flash:free)
OPENROUTER_MODEL=

# Required. PostgreSQL connection details for the news-retrieval database
NEWS_POSTGRES_PASSWORD=
NEWS_POSTGRES_HOST=postgres-news
NEWS_POSTGRES_PORT=5432
NEWS_POSTGRES_DB=news-retrieval
NEWS_POSTGRES_USER=news-retrieval
NEWS_POSTGRES_TEST_DB=news-retrieval-test

# Required. URL of the auth-service for Bearer token validation.
# news-retrieval forwards all /validate calls to this service; returns 503 if unset.
AUTH_SERVICE_URL=

# =============================================================================
# api-gateway
# =============================================================================

# Required. Base URLs for the upstream services.
# When running via docker compose these are set automatically in docker-compose.yml.
# Set them here only for running the gateway outside of compose.
GATEWAY_AUTH_URL=http://auth-service:8001
GATEWAY_NEWS_URL=http://news-retrieval:8000
GATEWAY_SIGNAL_URL=http://signal-detection:8002

# =============================================================================
# signal-detection
# =============================================================================

# Required. PostgreSQL connection details for the signal-detection database
SIGNAL_POSTGRES_PASSWORD=
SIGNAL_POSTGRES_DB=signal-detection
SIGNAL_POSTGRES_USER=signal-detection
SIGNAL_POSTGRES_HOST=postgres-signal

# Optional. Qdrant host (default: qdrant, the Docker Compose service name)
# QDRANT_HOST=qdrant
# QDRANT_PORT=6333

# Required. URL of the news-retrieval service for run_id validation.
NEWS_RETRIEVAL_URL=http://news-retrieval:8000

# Optional. Embedding model for corpus bootstrap (default: openai/text-embedding-3-large)
# Must use OpenRouter model prefix format when routing via OpenRouter.
# EMBEDDING_MODEL=openai/text-embedding-3-large

# Optional. Cosine similarity threshold for the deferred corpus promotion job.
# Articles scoring above this against the current centroid are confirmed as Signal.
# SIGNAL_THRESHOLD=0.5

# Optional. Embedding model for claim vectors (default: openai/text-embedding-3-small).
# Claims are short texts compared only against other claims, so small is sufficient.
# CLAIM_EMBEDDING_MODEL=openai/text-embedding-3-small

# Optional. Langfuse observability (tracing disabled if absent).
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
