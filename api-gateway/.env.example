# Required. Base URLs for upstream services.
# When running via docker compose these defaults are correct.
# Set manually only when running the gateway outside of compose.
GATEWAY_AUTH_URL=http://auth-service:8001
GATEWAY_NEWS_URL=http://news-retrieval:8000
GATEWAY_SIGNAL_URL=http://signal-detection:8002

# Comma-separated list of allowed CORS origins. Defaults to "*" if unset.
GATEWAY_CORS_ORIGINS=http://localhost:5173
