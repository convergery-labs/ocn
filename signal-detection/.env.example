# Required. PostgreSQL connection for signal-detection
POSTGRES_PASSWORD=
POSTGRES_DB=signal-detection
POSTGRES_USER=signal-detection
POSTGRES_HOST=postgres-signal
POSTGRES_PORT=5432

# Required. URL of the news-retrieval service for run_id validation
NEWS_RETRIEVAL_URL=http://news-retrieval:8000

# Required. OpenRouter credentials
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=inclusionai/ling-2.6-flash:free

# Optional. Qdrant host/port (defaults: qdrant / 6333)
# QDRANT_HOST=qdrant
# QDRANT_PORT=6333

# Optional. Cosine similarity threshold (default: 0.5)
# SIGNAL_THRESHOLD=0.5

# Optional. Embedding models
# EMBEDDING_MODEL=openai/text-embedding-3-large
# CLAIM_EMBEDDING_MODEL=openai/text-embedding-3-small

# Optional. Langfuse observability (tracing disabled if absent)
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
