# Required. PostgreSQL connection for auth-service
AUTH_POSTGRES_PASSWORD=
AUTH_POSTGRES_DB=auth-service
AUTH_POSTGRES_USER=auth-service
AUTH_POSTGRES_HOST=postgres-auth

# For postgres-auth sidecar (must match AUTH_POSTGRES_* values above)
POSTGRES_DB=auth-service
POSTGRES_USER=auth-service
POSTGRES_PASSWORD=

# Required. Plaintext admin API key seeded on first startup
# Must be of the form csec_<64 hex chars>
AUTH_ADMIN_API_KEY=

# Required. Admin user credentials seeded on first startup
ADMIN_USERNAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Required. PEM-encoded RS256 private key for JWT signing
AUTH_JWT_PRIVATE_KEY=

# Optional. JWT lifetime in seconds (default: 3600)
# AUTH_JWT_EXPIRY_SECONDS=3600
